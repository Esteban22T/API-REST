# =====================
# PROVEEDORES
# =====================

### Crear proveedor
POST http://localhost:3000/api/providers HTTP/1.1
Content-Type: application/json

{
  "_id": "Proveedor_001",
  "nombre": "Juan",
  "apellido": "Pérez",
  "correo": "juan.perez@example.com",
  "telefono": "123456789",
  "direccion": "Calle Falsa 123, Madrid",
  "compras": [
    {
      "compra_id": "compra_001",
      "fecha": "2024-08-01",
      "total": 150.00,
      "productos_servicios": [
        {
          "producto_servicio_id": "producto_001",
          "nombre": "Entrenamiento Personalizado",
          "precio": 100.00
        },
        {
          "producto_servicio_id": "producto_002",
          "nombre": "Suplemento Proteico",
          "precio": 50.00
        }
      ]
    }
  ]
}

### Obtener todos los proveedores
GET http://localhost:3000/api/providers HTTP/1.1

### Obtener proveedor por ID
GET http://localhost:3000/api/providers/Proveedor_001 HTTP/1.1

### Actualizar proveedor
PUT http://localhost:3000/api/providers/Proveedor_001 HTTP/1.1
Content-Type: application/json

{
  "nombre": "Juan",
  "apellido": "Ramirez",
  "correo": "juan.ramirez@example.com",
  "telefono": "999888777",
  "direccion": "Avenida Siempreviva 742, Bogotá"
}

### Eliminar proveedor
DELETE http://localhost:3000/api/providers/Proveedor_001 HTTP/1.1


# =====================
# CLIENTES
# =====================

### Crear cliente
POST http://localhost:3000/api/clients HTTP/1.1
Content-Type: application/json

{
  "_id": "cliente_001",
  "nombre": "Ana",
  "apellido": "García",
  "correo": "ana.garcia@example.com",
  "telefono": "987654321",
  "ventas": [
    {
      "venta_id": "venta_001",
      "fecha": "2024-08-02",
      "total": 200.00,
      "productos_servicios": [
        {
          "producto_servicio_id": "producto_003",
          "nombre": "Clase de Yoga",
          "precio": 150.00
        },
        {
          "producto_servicio_id": "producto_004",
          "nombre": "Manta de Yoga",
          "precio": 50.00
        }
      ]
    }
  ]
}

### Obtener todos los clientes
GET http://localhost:3000/api/clients HTTP/1.1

### Obtener cliente por ID
GET http://localhost:3000/api/clients/cliente_001 HTTP/1.1

### Actualizar cliente
PUT http://localhost:3000/api/clients/cliente_001 HTTP/1.1
Content-Type: application/json

{
  "nombre": "Ana",
  "apellido": "Martínez",
  "correo": "ana.martinez@example.com",
  "telefono": "111222333"
}

### Eliminar cliente
DELETE http://localhost:3000/api/clients/cliente_001 HTTP/1.1


# =====================
# PRODUCTOS Y SERVICIOS
# =====================

### Crear producto/servicio 1
POST http://localhost:3000/api/products HTTP/1.1
Content-Type: application/json

{
  "_id": "producto_001",
  "nombre": "Entrenamiento Personalizado",
  "descripcion": "Sesión de entrenamiento personalizado con un entrenador certificado.",
  "precio": 100.00,
  "tipo": "Servicio"
}

### Crear producto/servicio 2
POST http://localhost:3000/api/products HTTP/1.1
Content-Type: application/json

{
  "_id": "producto_002",
  "nombre": "Suplemento Proteico",
  "descripcion": "Proteína en polvo para apoyar la ganancia muscular.",
  "precio": 50.00,
  "tipo": "Producto"
}

### Obtener todos los productos
GET http://localhost:3000/api/products HTTP/1.1

### Obtener producto por ID
GET http://localhost:3000/api/products/producto_001 HTTP/1.1

### Actualizar producto
PUT http://localhost:3000/api/products/producto_001 HTTP/1.1
Content-Type: application/json

{
  "nombre": "Entrenamiento Personalizado Premium",
  "descripcion": "Sesión de entrenamiento personalizado con nutricionista incluido.",
  "precio": 150.00,
  "tipo": "Servicio"
}

### Eliminar producto
DELETE http://localhost:3000/api/products/producto_001 HTTP/1.1


# =====================
# COMPRAS
# =====================

### Crear compra
POST http://localhost:3000/api/purchases HTTP/1.1
Content-Type: application/json

{
  "_id": "compra_001",
  "proveedor_id": "Proveedor_001",
  "fecha": "2024-08-01",
  "total": 150.00,
  "productos_servicios": [
    {
      "producto_servicio_id": "producto_001",
      "nombre": "Entrenamiento Personalizado",
      "precio": 100.00
    },
    {
      "producto_servicio_id": "producto_002",
      "nombre": "Suplemento Proteico",
      "precio": 50.00
    }
  ]
}

### Obtener todas las compras
GET http://localhost:3000/api/purchases HTTP/1.1

### Obtener compra por ID
GET http://localhost:3000/api/purchases/compra_001 HTTP/1.1

### Actualizar compra
PUT http://localhost:3000/api/purchases/compra_001 HTTP/1.1
Content-Type: application/json

{
  "proveedor_id": "Proveedor_001",
  "fecha": "2024-08-05",
  "total": 200.00,
  "productos_servicios": [
    {
      "producto_servicio_id": "producto_001",
      "nombre": "Entrenamiento Personalizado",
      "precio": 200.00
    }
  ]
}

### Eliminar compra
DELETE http://localhost:3000/api/purchases/compra_001 HTTP/1.1


# =====================
# VENTAS
# =====================

### Crear venta
POST http://localhost:3000/api/sales HTTP/1.1
Content-Type: application/json

{
  "_id": "venta_001",
  "cliente_id": "cliente_001",
  "fecha": "2024-08-02",
  "total": 200.00,
  "productos_servicios": [
    {
      "producto_servicio_id": "producto_003",
      "nombre": "Clase de Yoga",
      "precio": 150.00
    },
    {
      "producto_servicio_id": "producto_004",
      "nombre": "Manta de Yoga",
      "precio": 50.00
    }
  ]
}

### Obtener todas las ventas
